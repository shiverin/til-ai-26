# Host-only virtualenv must never be baked into the image.
src/.venv

# Python / notebook caches
**/__pycache__
**/*.pyc
**/.ipynb_checkpoints
**/.pytest_cache

# HuggingFace cache lock files — not needed inside the image.
models/.locks

# Tests and dev-only tooling are not needed at runtime.
tests
conftest.py
eval_local.py

# NOTE: models/ is intentionally NOT ignored — the container runs offline and
# needs the pre-downloaded weights copied in via `COPY models ./models`.

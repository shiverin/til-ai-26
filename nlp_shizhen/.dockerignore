# Host-only virtualenv must never be baked into the image.
src/.venv

# Python / notebook caches
**/__pycache__
**/*.pyc
**/.ipynb_checkpoints
**/.pytest_cache

# HuggingFace cache lock files — not needed inside the image.
models/.locks

# Adversarial-trigger search tooling + logs are host-side only. trigger.json
# itself IS copied in explicitly by the Dockerfile and must NOT be ignored.
gcg_universal.py
probe_ae.py
gcg.log

# Dev / benchmarking / progress files not needed at runtime.
tests
test
conftest.py
eval_local.py
eval_results.json
bench_throughput.py
PROGRESS.md
raft_build_data.py
raft_train.py
raft_data

# NOTE: models/ is intentionally NOT ignored — the container runs offline
# (til test uses --network no_internet) and needs the pre-downloaded weights.

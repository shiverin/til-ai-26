# Copy to .env and fill in. Only OPENROUTER_API_KEY matters for the LLM agent.

# Which template to serve: "algo" (no key needed) or "llm".
AGENT=algo

# Required only for AGENT=llm. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the model the llm template uses (any your key can reach).
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Port your server listens on (the competition expects 6700).
PORT=6700
